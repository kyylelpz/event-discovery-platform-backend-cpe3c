NODE_ENV=production

#SerpAPI
SERPAPI_KEY=

# MongoDB
MONGO_URI=
MONGO_URI_EVENT=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.eventcinity.com/api/auth/google/callback
JWT_SECRET=

# Email Delivery
# Valid EMAIL_PROVIDER values: resend
EMAIL_PROVIDER=resend
EMAIL_FROM_ADDRESS=noreply@eventcinity.com
EMAIL_FROM_NAME=Eventcinity
EMAIL_FROM_DOMAIN=eventcinity.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@eventcinity.com
RESEND_FROM_NAME=Eventcinity

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
EVENT_IMAGE_MAX_SIZE_MB=8
AVATAR_IMAGE_MAX_SIZE_MB=5

# Frontend URL (for CORS)
CLIENT_URL=https://eventcinity.com
CLIENT_URLS=https://eventcinity.com,https://www.eventcinity.com

# Cross-subdomain auth
COOKIE_DOMAIN=.eventcinity.com
AUTH_SUCCESS_REDIRECT_URL=https://eventcinity.com/events
AUTH_FAILURE_REDIRECT_URL=https://eventcinity.com/signin
